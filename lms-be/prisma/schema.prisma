// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id    Int    @id @default(autoincrement())
  nama  String @unique @db.VarChar(50) // 'ADMIN', 'MAHASISWA', 'DOSEN' 
  users User[]
}

// 1. TABEL USER
model User {
  nomorInduk String @id @db.VarChar(20) 
  nama       String @db.VarChar(100) 
  email      String @unique @db.VarChar(100) 
  password   String @db.VarChar(255) 
  telepon       String?       @db.VarChar(20)
  fotoUrl       String?       @db.VarChar(500)
  roleId Int 
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade) 

  mahasiswa      Mahasiswa? 
  dosen          Dosen? 
  nilai          Nilai[] 
  komentarForum  KomentarForum[] 
  forumDiskusi   ForumDiskusi[]
  likesForum LikeForum[]
}

// 2. TABEL MAHASISWA
model Mahasiswa {
  nim        String @id @db.VarChar(20) 
  nomorInduk String @unique @db.VarChar(20) 
  user       User   @relation(fields: [nomorInduk], references: [nomorInduk], onDelete: Cascade) 
  
  tugas            Tugas[] 
  presensi         Presensi[] 
  progressTugas    ProgressTugas[] 
  pengumpulanTugas PengumpulanTugas[] 
  anggotaKelompok AnggotaKelompok[]
}

// 3. TABEL DOSEN
model Dosen {
  nip        String @id @db.VarChar(20) 
  nomorInduk String @unique @db.VarChar(20) 
  user       User   @relation(fields: [nomorInduk], references: [nomorInduk], onDelete: Cascade) 
  nidn          String?      @db.VarChar(20) // Tambahan
  bidang        String?      @db.VarChar(100) // Tambahan
  ruangKantor   String?      @db.VarChar(50) // Tambahan
  mataKuliah    MataKuliah[] // Back-relation ke MataKuliah
}

// 4. TABEL MATA KULIAH
model MataKuliah {
  idMataKuliah   Int    @id @default(autoincrement()) 
  namaMataKuliah String @db.VarChar(150) 
  nipDosen       String?  @db.VarChar(20)
  dosen          Dosen?   @relation(fields: [nipDosen], references: [nip])
  jadwal         String?  @db.VarChar(100) // Contoh: "Senin,Rabu,Jumat" atau "Selasa,Kamis"
  
  nilai         Nilai[] 
  kuis          Kuis[] 
  forumDiskusi  ForumDiskusi[] 
  modulAjar     ModulAjar[] 
  kelompok      Kelompok[] 
  tugas         Tugas[] 
  presensi      Presensi[] 
  progressTugas ProgressTugas[] 
}

// 5. TABEL NILAI
model Nilai {
  idNilai      Int      @id @default(autoincrement()) 
  nomorInduk   String   @db.VarChar(20) 
  idMataKuliah Int 
  nilaiTugas   Decimal? @db.Decimal(5, 2) 
  nilaiKuis    Decimal? @db.Decimal(5, 2) 
  nilaiAkhir   Decimal? @db.Decimal(5, 2) 
  semester     Int?     // Ditambahkan untuk Transkrip Nilai 
  
  user       User       @relation(fields: [nomorInduk], references: [nomorInduk], onDelete: Cascade) 
  mataKuliah MataKuliah @relation(fields: [idMataKuliah], references: [idMataKuliah], onDelete: Cascade) 
}

// 6. TABEL KUIS
model Kuis {
  idKuis       Int        @id @default(autoincrement())
  idMataKuliah Int
  judul        String     @db.VarChar(200)
  deadlineKuis DateTime?
  skor         Int?
  
  mataKuliah   MataKuliah @relation(fields: [idMataKuliah], references: [idMataKuliah], onDelete: Cascade)
  soal         Soal[]
}

// 7. TABEL SOAL
model Soal {
  idSoal         Int              @id @default(autoincrement())
  idKuis         Int
  pertanyaan     String           @db.Text
  kunciJawaban   String?          @db.VarChar(10)
  skor           Int?
  
  kuis           Kuis             @relation(fields: [idKuis], references: [idKuis], onDelete: Cascade)
  pilihanJawaban PilihanJawaban[]
}

// 8. TABEL PILIHAN JAWABAN
model PilihanJawaban {
  idPilihan   Int    @id @default(autoincrement())
  idSoal      Int
  teksJawaban String @db.Text
  
  soal        Soal   @relation(fields: [idSoal], references: [idSoal], onDelete: Cascade)
}

// 9. TABEL FORUM DISKUSI
model ForumDiskusi {
  idForumDiskusi Int             @id @default(autoincrement())
  idMataKuliah   Int
  judul          String          @db.VarChar(200)
  isiForum       String?         @db.Text
  lampiran       String?         @db.VarChar(255) // Tambahan untuk file upload
  createdAt      DateTime        @default(now())
  
  mataKuliah     MataKuliah      @relation(fields: [idMataKuliah], references: [idMataKuliah], onDelete: Cascade)
  komentarForum  KomentarForum[]
  likes          LikeForum[]     // Relasi ke tabel Like
  nomorInduk  String  @db.VarChar(20) // Sesuaikan dengan Primary Key di tabel User
  user        User    @relation(fields: [nomorInduk], references: [nomorInduk], onDelete: Cascade)
}


model KomentarForum {
  idKomentar     Int             @id @default(autoincrement())
  nomorInduk     String          @db.VarChar(20)
  idForum        Int
  isiKomentar    String?         @db.Text
  createdAt      DateTime        @default(now())

  user           User            @relation(fields: [nomorInduk], references: [nomorInduk], onDelete: Cascade)
  forum          ForumDiskusi    @relation(fields: [idForum], references: [idForumDiskusi], onDelete: Cascade)
}

// Tabel baru untuk fitur Like
model LikeForum {
  idLike         Int             @id @default(autoincrement())
  nomorInduk     String          @db.VarChar(20)
  idForum        Int

  user           User            @relation(fields: [nomorInduk], references: [nomorInduk], onDelete: Cascade)
  forum          ForumDiskusi    @relation(fields: [idForum], references: [idForumDiskusi], onDelete: Cascade)

  @@unique([nomorInduk, idForum]) // 1 user hanya bisa like 1 kali per forum
}

// 11. TABEL MODUL AJAR (Diperbarui)
model ModulAjar {
  idModulAjar  Int        @id @default(autoincrement())
  idMataKuliah Int
  judul        String     @db.VarChar(200)
  tipe_modul   String?    @db.VarChar(50) // PDF, Video, Link, Presentasi, Dokumen, Spreadsheet
  deskripsi    String?    @db.Text
  url          String?    @db.VarChar(255)
  fileUrl      String?    @db.VarChar(255)
  ukuran       String?    @db.VarChar(50)
  tanggal      DateTime?  @default(now()) @db.Date
  diunduh      Int        @default(0)
  canDownload  Boolean    @default(true)

  mataKuliah   MataKuliah @relation(fields: [idMataKuliah], references: [idMataKuliah], onDelete: Cascade)
}

// 12. TABEL KELOMPOK
// Update pada tabel Kelompok
model Kelompok {
  idKelompok     Int       @id @default(autoincrement())
  idMataKuliah   Int       
  namaKelompok   String    @db.VarChar(100)
  warna          String?   @db.VarChar(10)  // Contoh: "#4b53bc"
  tugasName      String?   @db.VarChar(200) // Nama tugas kelompok
  progress       Int       @default(0)
  status         String    @default("Not Started") @db.VarChar(20)
  submitted      Boolean   @default(false)

  mataKuliah     MataKuliah        @relation(fields: [idMataKuliah], references: [idMataKuliah], onDelete: Cascade)
  anggota        AnggotaKelompok[]
  pengumpulan    PengumpulanTugas[]
}

// Tabel baru untuk Anggota Kelompok & Nilai
model AnggotaKelompok {
  idAnggota      Int       @id @default(autoincrement())
  idKelompok     Int
  nim            String    @db.VarChar(20)
  nilaiTugas     Decimal?  @db.Decimal(5, 2) // Nilai khusus untuk tugas kelompok ini

  kelompok       Kelompok  @relation(fields: [idKelompok], references: [idKelompok], onDelete: Cascade)
  mahasiswa      Mahasiswa @relation(fields: [nim], references: [nim], onDelete: Cascade)

  @@unique([idKelompok, nim])
}

// 13. TABEL TUGAS
model Tugas {
  idTugas       Int        @id @default(autoincrement())
  idMataKuliah  Int
  nim           String     @db.VarChar(20)
  judul         String     @db.VarChar(200)
  detailTugas   String?    @db.Text
  deadlineTugas DateTime?
  fileJawaban   String?    @db.VarChar(255)
  
  mataKuliah    MataKuliah @relation(fields: [idMataKuliah], references: [idMataKuliah], onDelete: Cascade)
  mahasiswa     Mahasiswa  @relation(fields: [nim], references: [nim], onDelete: Cascade)
  pengumpulanTugas PengumpulanTugas[]
}

// 14. TABEL PRESENSI
model Presensi {
  idPresensi      Int @id @default(autoincrement()) 
  nim             String @db.VarChar(20) 
  idMataKuliah    Int 
  tanggalPertemuan DateTime? @db.Date 
  waktuPresensi   DateTime?
  statusKehadiran StatusKehadiran? @default(Hadir) 
  
  mahasiswa  Mahasiswa @relation(fields: [nim], references: [nim], onDelete: Cascade) 
  mataKuliah MataKuliah @relation(fields: [idMataKuliah], references: [idMataKuliah], onDelete: Cascade) 
}

enum StatusKehadiran {
  Hadir 
  Izin 
  Sakit 
  Alpha 
}

// 15. TABEL PROGRESS TUGAS
model ProgressTugas {
  idTugas       Int        @id @default(autoincrement())
  idMataKuliah  Int
  nim           String     @db.VarChar(20)
  judul         String?    @db.VarChar(200)
  detailTugas   String?    @db.Text
  deadlineTugas DateTime?
  fileJawaban   String?    @db.VarChar(255)
  
  mataKuliah    MataKuliah @relation(fields: [idMataKuliah], references: [idMataKuliah], onDelete: Cascade)
  mahasiswa     Mahasiswa  @relation(fields: [nim], references: [nim], onDelete: Cascade)
}

// 16. TABEL PENGUMPULAN TUGAS
model PengumpulanTugas {
  idPengumpulan Int       @id @default(autoincrement())
  idKelompok    Int?
  idTugas       Int
  nim           String    @db.VarChar(20)
  judul         String?   @db.VarChar(200)
  detailTugas   String?   @db.Text
  deadlineTugas DateTime?
  fileJawaban   String?   @db.VarChar(255)
  
  kelompok      Kelompok? @relation(fields: [idKelompok], references: [idKelompok], onDelete: Cascade)
  tugas         Tugas     @relation(fields: [idTugas], references: [idTugas], onDelete: Cascade)
  mahasiswa     Mahasiswa @relation(fields: [nim], references: [nim], onDelete: Cascade)
}
